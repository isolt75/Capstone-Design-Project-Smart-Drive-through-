# Smart Drive-through Main Server (FastAPI) - 환경변수
# 이 파일을 .env로 복사해 값을 채운다.

# === Database (MySQL) ===
# 로컬 MySQL 8.0 기준. 비밀번호는 본인 환경에 맞게 수정.
DB_URL=mysql+pymysql://root:1234@127.0.0.1:3306/dt_database?charset=utf8mb4

# === CORS (프론트 dev origin) ===
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === 엣지 업로드 저장 경로 (이미지/오디오 백업) ===
UPLOAD_DIR=./uploads

# === Clova Speech (STT, Short Sentence) ===
# 엣지와 동일 키 재사용. 비워두면 /api/stt 는 503 반환(나머지 기능은 정상).
CLOVA_INVOKE_URL=https://clovaspeech-gw.ncloud.com/recog/v1/stt
CLOVA_SECRET_KEY=
CLOVA_LANGUAGE=Kor

# === Clova Studio (HyperCLOVA X, 추천 LLM) ===
# STT 와는 별개 제품/키. 기존 고객 추천을 LLM 으로 생성한다.
# 비워두면 추천이 DB 휴리스틱(personalized_top)으로 자동 폴백(나머지 기능은 정상).
CLOVA_STUDIO_API_KEY=
CLOVA_STUDIO_URL=https://clovastudio.stream.ntruss.com/testapp/v1/chat-completions/HCX-003
